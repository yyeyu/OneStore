# Default local DB contour: PostgreSQL on 127.0.0.1:5433
ONESTORE_APP_NAME=OneStore
ONESTORE_ENVIRONMENT=local
ONESTORE_DEBUG=false
ONESTORE_HOST=127.0.0.1
ONESTORE_PORT=8000
ONESTORE_LOG_LEVEL=INFO
ONESTORE_LOG_FORMAT=text
ONESTORE_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/onestore
ONESTORE_DB_ECHO=false
ONESTORE_DB_POOL_PRE_PING=true
